DATABASE_URL="file:./dev.db"
WORKER_POLL_MS=3000

# Worker parallelism (conservative defaults for XVIDEOS)
WORKER_CONCURRENCY=4
WORKER_PROXY_CONCURRENCY=1
WORKER_OUTREACH_CONCURRENCY=2
WORKER_START_STAGGER_MS=1500
WORKER_STALE_JOB_MS=900000
HEADLESS=true

# Ban security — outreach throttling
REQUIRE_PROXY_FOR_OUTREACH=true
OUTREACH_DELAY_MIN_MS=5000
OUTREACH_DELAY_MAX_MS=12000
OUTREACH_BATCH_PAUSE_MIN_MS=15000
OUTREACH_BATCH_PAUSE_MAX_MS=35000
OUTREACH_HOURLY_CAP_PER_ACCOUNT=40
SUBSCRIBE_STAGGER_MS=45000

# Stealth mode — slower outreach, lower caps, proxy on every job, anti-detect browser
STEALTH_MODE=false

# Auto warmup when worker has idle slots (skipped while ADD_FRIENDS pending)
AUTO_WARMUP_ENABLED=true
AUTO_WARMUP_INTERVAL_MIN=90
AUTO_WARMUP_DURATION_MIN=3
AUTO_WARMUP_MAX_PER_CYCLE=2

# Cooldown after XVIDEOS friend-request limit / failed friends batch
FRIEND_LIMIT_COOLDOWN_HOURS=6
FRIENDS_FAIL_COOLDOWN_HOURS=1

# Optional — auto-creates proxy on startup (Proxies page / API load)
PROXY_NAME="My VPN"
PROXY_HOST=""
PROXY_PORT="8080"
PROXY_TYPE="HTTP"
PROXY_USERNAME=""
PROXY_PASSWORD=""
PROXY_COUNTRY="US"