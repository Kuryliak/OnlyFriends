{
  "name": "onlyfriends",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "worker": "tsx src/worker/index.ts",
    "workers": "WORKER_CONCURRENCY=1 WORKER_ID=worker-1 tsx src/worker/index.ts & WORKER_CONCURRENCY=1 WORKER_ID=worker-2 tsx src/worker/index.ts & WORKER_CONCURRENCY=1 WORKER_ID=worker-3 tsx src/worker/index.ts & WORKER_CONCURRENCY=1 WORKER_ID=worker-4 tsx src/worker/index.ts & wait",
    "monitor:bans": "tsx src/scripts/monitor-bans.ts",
    "proxy:seed": "tsx scripts/seed-proxy.ts",
    "proxy:test": "tsx scripts/test-proxy.ts",
    "dev:all": "npm run worker & npm run dev",
    "mac:start": "bash scripts/mac/launch.sh",
    "mac:stop": "bash \"Остановить OnlyFriends.command\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "playwright": "^1.52.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.4",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}